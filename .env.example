# ============================================================
# calserver-yii V1 – Konfigurationsvorlage
# Datei kopieren: cp .env.example .env  (dann anpassen)
# ============================================================

# --- Domain & TLS -------------------------------------------------
VIRTUAL_HOST=calendar.example.com
LETSENCRYPT_HOST=calendar.example.com
LETSENCRYPT_EMAIL=admin@example.com

# --- Laravel App --------------------------------------------------
# Generieren mit: openssl rand -base64 32
LARAVEL_APP_KEY=base64:CHANGE_ME_GENERATE_WITH_OPENSSL

APP_ENV=production
APP_DEBUG=false
APP_URL=https://calendar.example.com

# --- MySQL (V1 Datenbank) -----------------------------------------
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=calserver
MYSQL_USER=calserver
MYSQL_PASSWORD=change_me_db

# --- Docker Hub Zugangsdaten (vom Support erhalten) ---------------
DOCKER_USERNAME=
DOCKER_TOKEN=

# ============================================================
# V2 Stack (optional – nur aktivieren wenn V2 lizenziert)
# ============================================================
ENABLE_V2=false

# Datenbankverbindung für V2: mysql | pgsql
V2_DB_CONNECTION=mysql

# PostgreSQL (nur wenn V2_DB_CONNECTION=pgsql)
PG_PASSWORD=change_me_pg
PG_DATABASE=calserver_v2
PG_USER=calserver_v2

# V2 API Base URL (intern, wird vom Frontend genutzt)
V2_API_URL=http://calserver-api-v2:8000
